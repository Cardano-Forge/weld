{
  "name": "@ada-anvil/weld-plugin-hodei",
  "version": "0.0.2",
  "devDependencies": {
    "@ada-anvil/weld": "*",
    "@biomejs/biome": "2.4.4",
    "@microsoft/api-extractor": "^7.57.4",
    "@types/node": "^25.4.0",
    "@weld/biome": "*",
    "@weld/tsconfig": "*",
    "typescript": "~5.9.3",
    "unplugin-dts": "^1.0.0-beta.6",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "vite",
    "build:client": "vite build --config ./vite.client.ts",
    "build:cdn": "vite build --config ./vite.cdn.ts",
    "build": "tsc && npm run build:client && npm run build:cdn",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "lint": "biome check --write .",
    "test:watch": "vitest --passWithNoTests",
    "test": "vitest run --passWithNoTests",
    "pre": "npm run lint && npm run check && npm run build && npm run test"
  },
  "type": "module",
  "peerDependencies": {
    "@ada-anvil/weld": ">=0.7.0"
  },
  "dependencies": {
