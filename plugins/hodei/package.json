{
  "name": "weld-plugin-hodei",
  "version": "0.0.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "lint": "biome check --write .",
    "test:watch": "vitest",
    "test": "vitest run",
    "pre": "bun run lint && bun run check && bun run build && bun run test"
  },
  "type": "module"
}
