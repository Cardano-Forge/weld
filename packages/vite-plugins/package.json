    "build": "vite build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@weld/biome": "*",
    "@weld/tsconfig": "*",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
